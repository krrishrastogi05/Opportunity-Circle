generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum CompanyCategory {
  BIG_TECH
  PRODUCT_BASED
  SERVICE_BASED
  FINTECH
  QUANT_HFT
  AI_ML
  SAAS
  STARTUP
  CONSULTING
  RESEARCH_LAB
  EDTECH
  HEALTHTECH
  ECOMMERCE
}

enum HiringStyle {
  DSA_HEAVY
  PROJECT_HEAVY
  CP_FRIENDLY
  CAMPUS_FOCUSED
  OFF_CAMPUS_FRIENDLY
  OPEN_SOURCE_FRIENDLY
  HACKATHON_FRIENDLY
  REFERRAL_HEAVY
  SYSTEM_DESIGN_HEAVY
}

enum CandidateLevel {
  BEGINNER_FRIENDLY
  INTERMEDIATE
  ADVANCED
  ELITE
}

enum CampusPattern {
  TIER_1_ONLY
  SELECTED_TIER_2
  BROAD_CAMPUS
  MOSTLY_OFF_CAMPUS
  VARIES_YEARLY
  UNKNOWN
}

enum SkillImportance {
  SOMETIMES_RELEVANT  // ★   — nice to have
  GENERALLY_IMPORTANT // ★★  — commonly expected
  WIDELY_ESSENTIAL    // ★★★ — almost always matters
}

enum SkillCategory {
  DSA_CP
  SYSTEM_DESIGN
  CS_FUNDAMENTALS
  SOFT_SKILLS
  TOOLS_ECOSYSTEM
  DOMAIN_SPECIFIC
}

enum OpportunityKind {
  CAMPUS_PLACEMENT
  INTERNSHIP
  FULL_TIME
  HACKATHON_ROUTE
  OPEN_SOURCE_ROUTE
  RESEARCH_ROLE
  FELLOWSHIP
  STARTUP_ROLE
  FREELANCE
}

// ─────────────────────────────────────────────────────────────
// COMPANY
// ─────────────────────────────────────────────────────────────

model Company {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?  // URL / path to logo image
  tagline     String?  // one-liner for card subtitle
  description String   @db.Text // general hedged description

  // Classification
  categories     CompanyCategory[]
  hiringStyles   HiringStyle[]
  dsaScore       Int?             // 1–10, community perception score
  dsaLabel       String?          // e.g. "Medium-Hard generally expected"
  candidateLevel CandidateLevel?
  campusPattern  CampusPattern?

  // What opportunity types this company is associated with
  opportunityTypes OpportunityKind[]

  // Rich text expectation descriptions (hedged language required)
  internExpectation   String? @db.Text
  fresherExpectation  String? @db.Text
  generalNotes        String? @db.Text

  // Relations
  companySkills    CompanySkill[]
  relatedFrom      CompanyRelation[] @relation("CompanyA")
  relatedTo        CompanyRelation[] @relation("CompanyB")

  published Boolean  @default(false) // draft until ready
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// SKILL
// ─────────────────────────────────────────────────────────────

model Skill {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  description  String        @db.Text // plain English explanation
  whyItMatters String?       @db.Text // why companies and recruiters care
  category     SkillCategory

  // Relations
  companySkills        CompanySkill[]
  skillOpportunities   SkillOpportunity[]

  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// COMPANY ↔ SKILL  (junction with importance rating + note)
// ─────────────────────────────────────────────────────────────

model CompanySkill {
  id         String          @id @default(cuid())
  company    Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId  String
  skill      Skill           @relation(fields: [skillId], references: [id], onDelete: Cascade)
  skillId    String
  importance SkillImportance
  note       String?         // e.g. "LLD matters more at senior level"

  @@unique([companyId, skillId])
}

// ─────────────────────────────────────────────────────────────
// COMPANY ↔ COMPANY  (similarity relation, bidirectional)
// ─────────────────────────────────────────────────────────────

model CompanyRelation {
  id         String  @id @default(cuid())
  companyA   Company @relation("CompanyA", fields: [companyAId], references: [id], onDelete: Cascade)
  companyAId String
  companyB   Company @relation("CompanyB", fields: [companyBId], references: [id], onDelete: Cascade)
  companyBId String
  reason     String? // e.g. "Both are DSA-heavy product companies"

  @@unique([companyAId, companyBId])
}

// ─────────────────────────────────────────────────────────────
// OPPORTUNITY TYPE
// ─────────────────────────────────────────────────────────────

model OpportunityType {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  kind        OpportunityKind @unique
  description String          @db.Text
  whoIsItFor  String?         @db.Text // beginner/intermediate/advanced — plain text
  howToAccess String?         @db.Text // how students typically find/access this
  selectivity String?         // e.g. "Highly competitive globally"
  timeline    String?         // e.g. "Applications typically open in Dec–Jan"
  icon        String?         // lucide icon name for UI

  skillOpportunities SkillOpportunity[]

  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// SKILL ↔ OPPORTUNITY TYPE  (junction)
// ─────────────────────────────────────────────────────────────

model SkillOpportunity {
  id            String          @id @default(cuid())
  skill         Skill           @relation(fields: [skillId], references: [id], onDelete: Cascade)
  skillId       String
  opportunity   OpportunityType @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  opportunityId String

  @@unique([skillId, opportunityId])
}

// ─────────────────────────────────────────────────────────────
// EXPECTATION GUIDE
// ─────────────────────────────────────────────────────────────

model ExpectationGuide {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  targetPath String   // e.g. "big-tech", "startup", "quant-hft", "open-source"
  summary    String   @db.Text
  content    Json     // structured content blocks (sections, paragraphs, skill refs)

  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// BLOG  (kept for admin auth compatibility — can be removed later)
// ─────────────────────────────────────────────────────────────

model Blog {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     Json
  excerpt     String?
  coverImage  String?
  visibility  String    @default("PRIVATE")
  category    String    @default("TECHNICAL")
  pin         String?
  published   Boolean   @default(false)
  tags        String[]
  readTime    Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?
}
